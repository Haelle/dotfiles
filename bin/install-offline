#!/usr/bin/env bash
# install-offline - Dotfiles installer (offline mode)
# Only requires access to package repositories (apt/pacman)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source libraries
source "$SCRIPT_DIR/lib/common.sh"
source "$SCRIPT_DIR/lib/packages.sh"
source "$SCRIPT_DIR/lib/symlink.sh"

# --- Main ---

header "Dotfiles Installer (offline mode)"
echo

# 1. Detect distribution
detect_distro

# 2. Install packages
OFFLINE_PACKAGES=(
    zsh
    tmux
    vim
    git
    git-delta
    fzf
    ripgrep
    fd
    bat
    universal-ctags
    curl
    htop
    tree
    jq
    openssh
    zsh-autosuggestions
    zsh-syntax-highlighting
    unzip
)

install_packages "${OFFLINE_PACKAGES[@]}"

# 3. Install Starship
install_starship

# 4. Git identity
setup_git_identity

# 5. Deploy symlinks (offline set)
deploy_offline_symlinks

# 6. Propose zsh as default shell
propose_zsh

# 7. Summary
print_summary "offline"
