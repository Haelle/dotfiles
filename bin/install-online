#!/usr/bin/env bash
# install-online - Dotfiles installer (online mode)
# Requires full internet access for Oh My ZSH, NeoVim plugins, LSP servers

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source libraries
source "$SCRIPT_DIR/lib/common.sh"
source "$SCRIPT_DIR/lib/packages.sh"
source "$SCRIPT_DIR/lib/symlink.sh"

# --- Main ---

header "Dotfiles Installer (online mode)"
echo

# 1. Detect distribution
detect_distro

# 2. Install packages (offline set + online extras)
ONLINE_PACKAGES=(
    zsh
    tmux
    vim
    git
    git-delta
    fzf
    ripgrep
    fd
    bat
    universal-ctags
    curl
    htop
    tree
    jq
    openssh
    zsh-autosuggestions
    zsh-syntax-highlighting
    unzip
    neovim
    nodejs
    npm
    python3
    pip
    wget
)

install_packages "${ONLINE_PACKAGES[@]}"

# 3. Install Starship
install_starship_online

# 4. Install Oh My ZSH + custom plugins
install_oh_my_zsh

# 5. Git identity
setup_git_identity

# 6. Deploy symlinks (online set)
deploy_online_symlinks

# 7. Bootstrap NeoVim plugins (headless)
header "Bootstrapping NeoVim plugins"
if command -v nvim &>/dev/null; then
    info "Installing plugins via lazy.nvim..."
    nvim --headless "+Lazy! sync" +qa 2>/dev/null || true
    success "NeoVim plugins installed"

    # 8. Install LSP servers via Mason (headless)
    info "Installing LSP servers via Mason..."
    nvim --headless "+MasonInstall lua-language-server pyright typescript-language-server bash-language-server gopls rust-analyzer ansible-language-server dockerfile-language-server yaml-language-server json-lsp" +qa 2>/dev/null || true
    success "LSP servers installed"
else
    warn "NeoVim not found, skipping plugin installation"
fi

# 9. Propose zsh as default shell
propose_zsh

# 10. Summary
print_summary "online"
