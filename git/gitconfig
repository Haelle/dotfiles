[include]
    path = ~/.gitconfig.local

[core]
    editor = vim
    autocrlf = input
    whitespace = fix
    excludesfile = ~/.gitignore_global
    pager = delta

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    autoSetupRemote = true
    default = current

[rebase]
    autostash = true
    autosquash = true

[merge]
    conflictstyle = diff3

[rerere]
    enabled = true

[diff]
    colorMoved = default

[delta]
    navigate = true
    line-numbers = true
    side-by-side = true
    syntax-theme = Dracula

[interactive]
    diffFilter = delta --color-only

[alias]
    st = status -sb
    co = checkout
    sw = switch
    br = branch
    ci = commit
    ca = commit --amend
    cm = commit -m
    lg = log --oneline --graph --decorate -20
    lga = log --oneline --graph --decorate --all
    p = push
    pf = push --force-with-lease
    pl = pull
    cancel = reset --soft HEAD~1
    wip = "!git add -A && git commit -m 'WIP'"
    unwip = "!git log -1 --format=%s | grep -q '^WIP$' && git reset HEAD~1"
    unstage = reset HEAD --
    last = log -1 HEAD --stat
    diff-staged = diff --cached
    contributors = shortlog -sn --no-merges
    aliases = config --get-regexp alias
    branches = branch -a --sort=-committerdate
    stashes = stash list
    tags = tag -l --sort=-v:refname
    cleanup = "!git branch --merged | grep -v '\\*\\|main\\|master\\|develop' | xargs -n 1 git branch -d"

[color]
    ui = auto

[help]
    autocorrect = prompt

[url "git@github.com:"]
    insteadOf = gh:
