{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "alwaysThinkingEnabled": true,
  "defaultMode": "bypassPermissions",
  "bypassPermissionsModeAccepted": true,
  "tui": "fullscreen",
  "agentPushNotifEnabled": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "permissions": {
    "deny": [
      "Read(**.env)",
      "Read(**.env.*)",
      "Read(**/*token*)",
      "Read(**/*TOKEN*)",
      "Read(**master.key)",
      "Read(**sandbox.key)",
      "Read(**staging.key)",
      "Read(**production.key)"
    ]
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "dsfr-skill@dsfr-skill": true,
    "frontend-design@claude-plugins-official": true,
    "fullstack-dev-skills@fullstack-dev-skills": true,
    "github@claude-plugins-official": true,
    "pixel-plugin@pixel-plugin": true,
    "spp@claude-spp": true,
    "superpowers@claude-plugins-official": true,
    "svelte@svelte": true
  },
  "extraKnownMarketplaces": {
    "claude-spp": {
      "source": {
        "source": "github",
        "repo": "mlolson/claude-spp"
      }
    },
    "dsfr-skill": {
      "source": {
        "source": "github",
        "repo": "numerique-gouv/dsfr-skill"
      }
    },
    "fullstack-dev-skills": {
      "source": {
        "source": "github",
        "repo": "jeffallan/claude-skills"
      }
    },
    "pixel-plugin": {
      "source": {
        "source": "github",
        "repo": "willibrandon/pixel-plugin"
      }
    },
    "svelte": {
      "source": {
        "source": "github",
        "repo": "sveltejs/ai-tools"
      }
    }
  }
}
