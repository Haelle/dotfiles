#!/bin/env bash
#
# install-offline - Installation des dotfiles

set -euo pipefail

# SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Charger les libs
source "./lib/common.sh"
source "./lib/deps.sh"
source "./lib/fish.sh"
source "./lib/git.sh"
source "./lib/ssh.sh"
source "./lib/tmux.sh"
source "./lib/neovim.sh"
source "./lib/claude.sh"
source "./lib/ngrok.sh"

MODULES=()

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS] [MODULES...]

Installation des dotfiles.

Modules disponibles: fish, git, ssh, tmux, neovim, claude, ngrok
Sans module spécifié, tout est installé.

Options:
    --dry-run    Affiche les actions sans les exécuter
    -h, --help   Affiche cette aide

Exemples:
    $(basename "$0") neovim          Installe uniquement NeoVim
    $(basename "$0") fish tmux       Installe Fish et Tmux
    $(basename "$0") --dry-run git   Dry-run pour Git uniquement

EOF
    exit 0
}

ALL_MODULES=(fish git ssh tmux neovim claude ngrok)

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                DRY_RUN=true
                shift
                ;;
            -h|--help)
                usage
                ;;
            fish|git|ssh|tmux|neovim|claude|ngrok)
                MODULES+=("$1")
                shift
                ;;
            *)
                log_error "Option inconnue: $1"
                usage
                ;;
        esac
    done

    if [[ ${#MODULES[@]} -eq 0 ]]; then
        MODULES=("${ALL_MODULES[@]}")
    fi
}

should_install() {
    local module="$1"
    for m in "${MODULES[@]}"; do
        [[ "$m" == "$module" ]] && return 0
    done
    return 1
}

main() {
    parse_args "$@"

    log_header "Installation des dotfiles"

    if [[ "$DRY_RUN" == true ]]; then
        log_warning "Mode dry-run activé - aucune modification ne sera effectuée"
        echo ""
    fi

    log_info "Dossier dotfiles: $DOTFILES_DIR"
    log_info "Dossier backup: $BACKUP_DIR"
    log_info "Modules: ${MODULES[*]}"
    echo ""

    # Installation
    install_deps
    should_install fish   && install_fish
    should_install git    && install_git
    should_install ssh    && install_ssh
    should_install tmux   && install_tmux
    should_install neovim && install_neovim
    should_install claude && install_claude
    should_install ngrok  && install_ngrok

    echo ""
    if [[ "$DRY_RUN" == true ]]; then
        log_warning "Dry-run terminé. Relancez sans --dry-run pour appliquer."
    else
        log_success "Installation terminée!"
    fi
}

main "$@"
