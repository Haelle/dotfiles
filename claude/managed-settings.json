{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enabledPlugins": {
    "dsfr-skill@dsfr-skill": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "solargraph@claude-code-lsps": true,
    "bash-language-server@claude-code-lsps": true,
    "terraform-ls@claude-code-lsps": true,
    "yaml-language-server@claude-code-lsps": true
  },
  "extraKnownMarketplaces": {
    "dsfr-skill": {
      "source": {
        "source": "github",
        "repo": "numerique-gouv/dsfr-skill"
      }
    },
    "claude-code-lsps": {
      "source": {
        "source": "github",
        "repo": "boostvolt/claude-code-lsps"
      }
    }
  },
  "permissions": {
    "deny": [
      "Read(**.env)",
      "Read(**.env.*)",
      "Read(**/*token*)",
      "Read(**/*TOKEN*)",
      "Read(**master.key)",
      "Read(**sandbox.key)",
      "Read(**staging.key)",
      "Read(**production.key)"
    ]
  }
}
